{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>truecharts/public//.github/renovate/main.json5"
  ],
  "timezone": "America/Chicago",
  "schedule": [
    "* 22-23,0-5 * * *"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/clusters/main/kubernetes/apps/karakeep/app/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "raw\\.githubusercontent\\.com/karakeep-app/karakeep/(?<currentValue>v?[0-9][^/\\s]*)/kubernetes/web-deployment\\.yaml",
        "raw\\.githubusercontent\\.com/karakeep-app/karakeep/(?<currentValue>v?[0-9][^/\\s]*)/kubernetes/web-service\\.yaml",
        "raw\\.githubusercontent\\.com/karakeep-app/karakeep/(?<currentValue>v?[0-9][^/\\s]*)/kubernetes/chrome-deployment\\.yaml",
        "raw\\.githubusercontent\\.com/karakeep-app/karakeep/(?<currentValue>v?[0-9][^/\\s]*)/kubernetes/chrome-service\\.yaml",
        "raw\\.githubusercontent\\.com/karakeep-app/karakeep/(?<currentValue>v?[0-9][^/\\s]*)/kubernetes/meilisearch-deployment\\.yaml",
        "raw\\.githubusercontent\\.com/karakeep-app/karakeep/(?<currentValue>v?[0-9][^/\\s]*)/kubernetes/meilisearch-service\\.yaml"
      ],
      "depNameTemplate": "karakeep-app/karakeep",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/clusters/main/kubernetes/apps/karakeep/app/configuration\\.yaml$/"
      ],
      "matchStrings": [
        "\\s*KARAKEEP_VERSION: \"?(?<currentValue>[^\"\\n]+)\"?"
      ],
      "depNameTemplate": "karakeep-app/karakeep",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "ghcr.io/siderolabs/kubelet",
        "ghcr.io/siderolabs/installer",
        "registry.k8s.io/kubectl"
      ],
      "groupName": "Sidero Labs updates",
      "dependencyDashboardApproval": true,
      "automerge": false
    },
    {
      "matchPackageNames": [
        "getmeili/meilisearch"
      ],
      "groupName": "Meilisearch updates",
      "dependencyDashboardApproval": true,
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "description": "Require manual approval for all Meilisearch updates due to potential breaking changes in minor versions"
    },
    {
      "matchDatasources": [
        "github-tags"
      ],
      "matchPackageNames": [
        "karakeep-app/karakeep"
      ],
      "groupName": "Karakeep upstream manifests",
      "description": "Track the Karakeep release tag used by the upstream Kubernetes manifest overlay"
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "rss-bridge",
        "rsshub"
      ],
      "groupName": "RSS applications auto-updates",
      "automerge": true,
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "description": "Auto-update rss-bridge and rsshub applications including major versions"
    },
    {
      "groupName": "all other dependencies",
      "groupSlug": "all-minor-patch",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchPackageNames": [
        "/.*/",
        "!ghcr.io/siderolabs/kubelet",
        "!ghcr.io/siderolabs/installer",
        "!getmeili/meilisearch",
        "!rss-bridge",
        "!rsshub"
      ]
    }
  ]
}
